#cloud-config
# Builder VM: bakes an OpenWrt x86_64 image with a uci-defaults script
# that injects our SSH pubkey and flips the single NIC from default
# LAN (192.168.1.1) to WAN (dhcp). Produces /root/openwrt-wrtbox-emu.qcow2
# which the orchestrator then pulls via sftp and uploads to Glance.
#
# Placeholders replaced before upload:
#   @@OPENWRT_PUBKEY@@  — contents of ~/.ssh/wrtbox-emu.pub
#   @@OPENWRT_VERSION@@ — e.g. 23.05.5

packages:
  - qemu-utils
  - kpartx
  - e2fsprogs
  - util-linux
  - curl

write_files:
  - path: /root/uci-defaults-99-wrtbox.sh
    permissions: "0755"
    content: |
      #!/bin/sh
      # Runs on first boot of OpenWrt (uci-defaults drops scripts that
      # succeeded → /tmp/.uci-defaults-run). Sets up SSH + DHCP WAN.

      mkdir -p /etc/dropbear
      cat > /etc/dropbear/authorized_keys <<'AUTHEOF'
      @@OPENWRT_PUBKEY@@
      AUTHEOF
      chmod 600 /etc/dropbear/authorized_keys

      # Flip the single NIC (eth0) from default LAN to a DHCP WAN so
      # the cloud DHCP hands us an IP and we become reachable.
      uci -q delete network.lan
      uci -q delete network.lan6
      uci set network.wan=interface
      uci set network.wan.device='eth0'
      uci set network.wan.proto='dhcp'
      uci set network.wan.peerdns='1'
      uci commit network

      # Allow SSH on the wan zone (default OpenWrt firewall blocks it).
      uci add firewall rule >/dev/null
      uci set firewall.@rule[-1].name='wrtbox-Allow-SSH'
      uci set firewall.@rule[-1].src='wan'
      uci set firewall.@rule[-1].proto='tcp'
      uci set firewall.@rule[-1].dest_port='22'
      uci set firewall.@rule[-1].target='ACCEPT'
      uci commit firewall

      # Bring up network + install xray + openssh-sftp-server in the
      # background so uci-defaults returns quickly and first-boot
      # completes.
      (
        sleep 5
        /etc/init.d/network restart
        sleep 15
        opkg update || true
        # xray-core is in packages (if available on this OpenWrt branch
        # as a prebuilt opkg). Fall back is to skip — wrtbox apply can
        # still validate uci, and xray-test fail degrades gracefully.
        opkg install xray-core openssh-sftp-server v2ray-geoip v2ray-geosite 2>&1 || true
        # xray looks up geoip.dat/geosite.dat next to its binary — symlink
        # from /usr/share/xray to /usr/bin so validation and runtime work.
        [ -e /usr/share/xray/geoip.dat ]   && ln -sf /usr/share/xray/geoip.dat   /usr/bin/geoip.dat   || true
        [ -e /usr/share/xray/geosite.dat ] && ln -sf /usr/share/xray/geosite.dat /usr/bin/geosite.dat || true
        /etc/init.d/firewall reload || true
      ) &

      exit 0

  - path: /root/build.sh
    permissions: "0755"
    content: |
      #!/bin/bash
      set -euxo pipefail
      cd /root
      VERSION=@@OPENWRT_VERSION@@
      URL="https://downloads.openwrt.org/releases/${VERSION}/targets/x86/64/openwrt-${VERSION}-x86-64-generic-ext4-combined.img.gz"

      curl -fLo ow.img.gz "$URL"
      # gzip exits 2 on "trailing garbage" (harmless warning seen on some
      # OpenWrt mirrors). Tolerate it as long as ow.img ends up populated.
      gunzip -f ow.img.gz || true
      [ -s ow.img ] || { echo "ow.img empty after gunzip"; exit 1; }

      # Expand disk so opkg install has breathing room (~512MB).
      truncate -s 1G ow.img

      # Rewrite partition table to let rootfs grow into the extra space.
      # OpenWrt combined images have: p1 kernel (~16MB), p2 rootfs.
      # We re-size p2 to fill the disk.
      PART_START=$(parted -m ow.img unit s print 2>/dev/null | awk -F: '$1=="2"{print $2}' | tr -d 's')
      parted -s ow.img resizepart 2 100%

      LOOP=$(losetup --find --show --partscan ow.img)
      # Wait for partition nodes.
      for i in 1 2 3 4 5; do
        [ -e "${LOOP}p2" ] && break
        sleep 1
        partprobe "$LOOP" || kpartx -av "$LOOP" || true
      done

      e2fsck -f -y "${LOOP}p2" || true
      resize2fs "${LOOP}p2"

      mkdir -p /mnt/rootfs
      mount "${LOOP}p2" /mnt/rootfs

      install -D -m 0755 /root/uci-defaults-99-wrtbox.sh \
        /mnt/rootfs/etc/uci-defaults/99-wrtbox-emu-init

      umount /mnt/rootfs
      losetup -d "$LOOP"

      qemu-img convert -f raw -O qcow2 ow.img /root/openwrt-wrtbox-emu.qcow2
      chmod 0644 /root/openwrt-wrtbox-emu.qcow2
      ls -la /root/openwrt-wrtbox-emu.qcow2 > /root/BUILD_DONE

runcmd:
  - [ bash, -lc, "bash /root/build.sh > /root/build.log 2>&1 || (echo FAILED > /root/BUILD_DONE; exit 1)" ]
