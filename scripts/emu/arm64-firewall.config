# Emulator-only firewall: accept everything. QEMU user-mode NAT already
# isolates the guest from anything except the host-forwarded :2222 port,
# so running without fw4's default "WAN input REJECT" zone is safe here
# and lets host-forwarded SSH reach dropbear. Do NOT use this config on
# real hardware — it disables all zone-based filtering.
config defaults
	option input 'ACCEPT'
	option output 'ACCEPT'
	option forward 'ACCEPT'
	option syn_flood '0'
